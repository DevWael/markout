<?xml version="1.0"?>
<ruleset name="Markout">
    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <file>src</file>
    <file>tests</file>
    <exclude-pattern>tests/bootstrap\.php$</exclude-pattern>
    <rule ref="PSR12"/>
    <!-- PHPUnit's idiomatic test_snake_case naming is exempted; PSR-12
         camelCase enforcement still applies to production code in src/. -->
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
</ruleset>
